use graphics_engine::graphics_engine::{HContext_t, HRenderSetup_t, HTexture_t, RenderContext};
use graphics_engine::render_pass::RenderPass;
use types::math::Matrix4;
use types::std_vector::Vector;

/// The flat, contiguous render-pass id enum. Every pass / first / last index in the render engine is
/// one of these. The render engine draws by pass-index range: the GBuffer from `RP_Z_OCCLUDERS` to
/// `RP_LAST_GBUFFER`, the scene from `RP_REFLECTIVE_WATER_PLANES` to `RP_LAST_MAIN`, and the
/// post-effects at `RP_POSTEFFECTS`. Named [`RenderPassId`] to avoid clashing with the [`RenderPass`]
/// type.
///
/// **Unverified:** this dump numbers `RP_POSTEFFECTS` and `RP_LAST_MAIN` one lower than the retail
/// range comments below describe; a one-pass build delta or comment drift, pending a `.text` check.
#[copyable]
pub enum RenderPassId: i32 {
    RP_NONE = 0x0,
    RP_TERRAINPATCH_CLEAR = 0x1,
    RP_TERRAINPATCH_HISTOGRAM = 0x2,
    RP_TERRAINPATCH_TRIANGLES = 0x3,
    RP_TERRAINPATCH_SETUPDETAIL = 0x4,
    RP_TERRAINPATCH_SETUP = 0x5,
    RP_TERRAINPATCH_MORPH_TARGET = 0x6,
    RP_TERRAINPATCH_ENUMERATION = 0x7,
    PRE_RP_SKY_LIGHTING = 0x8,
    PRE_RP_REFLECTION_PRE = 0x9,
    PRE_RP_REFLECTION_DISTANT_BACKDROP = 0xA,
    PRE_RP_REFLECTION_ATMOSPHERE = 0xB,
    PRE_RP_REFLECTION_CLOUDS = 0xC,
    PRE_RP_REFLECTION_DETAIL_BACKDROP = 0xD,
    PRE_RP_REFLECTION_MESH = 0xE,
    PRE_RP_REFLECTION_DISTANT_LIGHTS = 0xF,
    PRE_RP_REFLECTION_POST = 0x10,
    PRE_RP_ENVREFLECTION = 0x11,
    PRE_RP_CLOUDSHADOWS = 0x12,
    PRE_RP_VEGETATION_UPDATE = 0x13,
    PRE_RP_VEG_INT_RECENTER = 0x14,
    PRE_RP_VEGETATION_INTERACTION = 0x15,
    PRE_RP_STATIC_SHADOW_0 = 0x16,
    PRE_RP_STATIC_SHADOW_1 = 0x17,
    PRE_RP_STATIC_SHADOW_2 = 0x18,
    PRE_RP_STATIC_SHADOW_3 = 0x19,
    PRE_RP_STATIC_SHADOW_4 = 0x1A,
    PRE_RP_STATIC_SHADOW_5 = 0x1B,
    PRE_RP_STATIC_SHADOW_6 = 0x1C,
    PRE_RP_STATIC_SHADOW_7 = 0x1D,
    PRE_RP_SHADOW_0 = 0x1E,
    PRE_RP_SHADOW_1 = 0x1F,
    PRE_RP_SHADOW_2 = 0x20,
    PRE_RP_SHADOW_3 = 0x21,
    PRE_RP_SHADOW_4 = 0x22,
    PRE_RP_SHADOW_5 = 0x23,
    PRE_RP_SHADOW_6 = 0x24,
    PRE_RP_SHADOW_7 = 0x25,
    PRE_RP_SHADOW_REFLECTIVE_SUN_NEAR = 0x26,
    PRE_RP_SHADOW_REFLECTIVE_SUN_FAR = 0x27,
    PRE_RP_SHADOW_REFLECTIVE_CAMERA = 0x28,
    PRE_RP_WATER_CS_PRE = 0x29,
    PRE_RP_WATER_WAKES_PRE = 0x2A,
    PRE_RP_WATER_FOAM_PRE = 0x2B,
    PRE_RP_WATER_DISPLACEMENT_PRE = 0x2C,
    RP_RAIN_OCCLUDER = 0x2D,
    PRE_RP_LAST_PREPASS = 0x2E,
    RP_Z_OCCLUDERS = 0x2F,
    RP_Z_COARSE_PASS = 0x30,
    RP_Z_PASS = 0x31,
    RP_Z_AND_VELOCITY_PASS = 0x32,
    RP_Z_DEBUG_VISUALIZATION = 0x33,
    RP_CLEAR = 0x34,
    RP_ROAD_STENCIL = 0x35,
    RP_TERRAINPATCH_DETAIL_MID = 0x36,
    RP_TERRAINPATCH_DETAIL_LOW = 0x37,
    RP_TERRAINPATCH_BASEMESH_TESSELLATE_NEAR = 0x38,
    RP_TERRAINPATCH_BASEMESH_NEAR = 0x39,
    RP_TERRAINPATCH_BASEMESH_TESSELLATE_FAR = 0x3A,
    RP_TERRAINPATCH_BASEMESH_FAR = 0x3B,
    RP_TERRAINPATCH_BASEMESH_TESSELLATE_COLOR = 0x3C,
    RP_TERRAINPATCH_BASEMESH_COLOR = 0x3D,
    RP_TERRAIN_APPLY_NEAR_DETAILED = 0x3E,
    RP_TERRAIN_APPLY_NEAR = 0x3F,
    RP_TERRAIN_APPLY_FAR = 0x40,
    RP_MODELS_DYNAMIC = 0x41,
    RP_MODELS_DYNAMIC_MASK_DAMAGE_POST_EFFECT = 0x42,
    RP_MODELS_STATIC = 0x43,
    RP_MODELS_REFLECTION = 0x44,
    RP_UNDERWATER_VEGETATION = 0x45,
    RP_VEGETATION_OPAQUE = 0x46,
    RP_VEGETATIONFINS = 0x47,
    RP_VEGETATIONGROUP = 0x48,
    RP_VEGETATIONGROUP2 = 0x49,
    RP_TERRAIN_FOREST = 0x4A,
