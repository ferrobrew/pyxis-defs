    RP_Z_LOCK = 0x4D,
    RP_ROAD_JUNCTION = 0x4E,
    RP_ROAD_LAYERS = 0x4F,
    RP_ROAD_JUNCTION_OPAQUE = 0x50,
    RP_DOWNSAMPLE_DEPTH = 0x51,
    RP_DECALS = 0x52,
    RP_SCREEN_SPACE_DECALS = 0x53,
    RP_SCREEN_SPACE_ROAD_DECALS = 0x54,
    RP_LAST_GBUFFER = 0x55,
    RP_REFLECTIVE_WATER_PLANES = 0x56,
    RP_AO_VOLUMES = 0x57,
    RP_SSAO = 0x58,
    RP_SCREEN_SPACE_REFLECTIONS = 0x59,
    RP_GLOBAL_ILLUMINATION = 0x5A,
