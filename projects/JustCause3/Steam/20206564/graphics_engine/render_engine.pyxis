    RP_CONTRAILS = 0x7F,
    RP_GROUNDHAZE = 0x80,
    RP_PARTICLE_RIBBON = 0x81,
    RP_MODEL_HALO_POST = 0x82,
    RP_PARTICLE_LOWRES = 0x83,
    RP_SPOTLIGHT_VOLUMETRICS = 0x84,
    RP_WINDOW_DECALS = 0x85,
    RP_MODELS_REFRACT = 0x86,
    RP_PARTICLE_GENERAL = 0x87,
    RP_PARTICLE_DISTORT = 0x88,
    RP_PARTICLE_LOWRES_OVERLAY = 0x89,
    RP_SCENE_CAPTURE = 0x8A,
    RP_Z_FINAL_TRANSPARENT = 0x8B,
    RP_CLEAR_SCREEN_SPACE_SUBSURFACE_SKIN = 0x8C,
    RP_CLEAR_STENCIL = 0x8D,
    RP_GHOST_EFFECT = 0x8E,
    RP_OUTLINE_MASK = 0x8F,
    RP_OUTLINE_EFFECT = 0x90,
    RP_OUTLINE_EFFECT_NO_DEPTH = 0x91,
    RP_OUTLINE_EFFECT_BLUR = 0x92,
    RP_FINAL_TRANSPARENT = 0x93,
    RP_PARTICLE_ONSCREEN = 0x94,
    RP_POSTEFFECTS = 0x95,
    RP_LAST_MAIN = 0x96,
    POST_RP_FULLSCREEN_VIDEO = 0x97,
    RP_VEGETATION_SAMPLING = 0x98,
    POST_RP_POSTEFFECTS_GLOBAL = 0x99,
    POST_RP_UI = 0x9A,
    POST_RP_DEBUG_GFX = 0x9B,
    RP_RENDERPASS_COUNT = 0x9C,
}

#[singleton(0x142_ED0_E18), size(0x2220)]
pub type RenderEngine {
    /// The per-pass render-block-item lists: one vector of [`RenderPass`] pointers per pass id.
    /// [`DrawRenderPassRange`](RenderEngine::DrawRenderPassRange) and the per-frame list rotation walk
    /// this.
    #[address(0x80)]
    pub m_RenderPasses: [Vector<*mut RenderPass>; 157],
}
impl RenderEngine {
    /// The late render-pass step: finalizes and copies render targets under the context mutex.
    #[address(0x140_1C2_350)]
    pub fn PostDraw(&mut self, context: *const HContext_t);

    /// Draws every render block in the half-open pass-index range `[first, last)`: for each pass it
    /// walks the [`RenderPass`] list and vtable-dispatches each block.
    #[address(0x140_186_600)]
    pub fn DrawRenderPassRange(&mut self, ctx: *mut HContext_t, setup: *mut HRenderSetup_t, first: RenderPassId, last: RenderPassId);

    /// The GBuffer fill: binds two global textures, then draws the GBuffer pass range (the depth and
    /// velocity prefix, static and dynamic models, and decals).
    #[address(0x140_186_810)]
    pub fn DrawGBuffer(&mut self, ctx: *mut HContext_t, a3: i64, a4: *mut HTexture_t);

    /// Lighting, reflections, opaque, environment, water, and transparency: draws the scene pass
    /// range, then clears the global texture samplers.
    #[address(0x140_186_8A0)]
    pub fn Draw(&mut self, ctx: *mut HContext_t) -> u64;

    /// The post-effects pass: draws the `RP_POSTEFFECTS` range, whose block is
    /// [`RenderBlockPostEffects::Draw`].
    #[address(0x140_186_910)]
    pub fn DrawPosteffects(&mut self, ctx: *mut HContext_t, setup: *mut HRenderSetup_t);

    /// Uploads the global per-view constant buffer for the frame: lighting, fog, wetness, and the
    /// render camera's full (translation-bearing) view-projection and world position. This drives
    /// screen-space and non-geometry work, not opaque-geometry vertex placement.
    #[address(0x140_185_740)]
    pub fn SetGlobalShaderConstants(&mut self, ctx: *mut RenderContext);

    /// The per-frame TAA jitter: forwards to [`PostEffectsManager::ApplySubsampleJitter`], which
    /// post-multiplies a sub-pixel clip-space translation onto `proj` only at the T2X resolve mode.
    #[address(0x140_173_AA0)]
    pub fn ApplyJitterTransform(&mut self, proj: *mut Matrix4, width: i32, height: i32);

    /// Drains a separate deferred deletion list of render blocks, under its own critical section. Does
    /// not touch the per-pass draw lists.
    #[address(0x140_1A4_ED0)]
    pub fn EraseAllDeletedRenderBlocks(&mut self);
}
