    RP_DEFERRED_LIGHTS = 0x5C,
    RP_DEBUG_GI = 0x5D,
    RP_LINES = 0x5E,
    RP_OCCLUDERS_DEBUG = 0x5F,
    RP_BILLBOARD = 0x60,
    RP_OCCLUSION_QUERY = 0x61,
    RP_LAST_OPAQUE = 0x62,
    RP_STARS = 0x63,
    RP_SUN = 0x64,
    RP_MOON = 0x65,
    RP_SKYBOX = 0x66,
    RP_SKY_GRADIENT = 0x67,
    RP_FOG_GRADIENT = 0x68,
    RP_DEBUG_TRANSPARENCY = 0x69,
    RP_UNDERWATER_CLOUDS = 0x6A,
    RP_UNDERWATER_VEGETATION_TRANSPARENT = 0x6B,
    RP_COPY_FRAMEBUFFER = 0x6C,
    RP_WATER = 0x6D,
    RP_POST_WATER = 0x6E,
    RP_SKIDMARKS = 0x6F,
    RP_PRE_CLOUDS = 0x70,
    RP_LENSFLARE = 0x71,
    RP_POST_CLOUDS = 0x72,
    RP_APPLY_CLOUDS = 0x73,
    RP_FOG_VOLUME_GENERATE = 0x74,
    RP_FOG_VOLUME_UPSAMPLE = 0x75,
    RP_FOG_VOLUME_APPLY = 0x76,
    RP_MASK_WATER = 0x77,
    RP_MODELS_TRANSPARENT = 0x78,
